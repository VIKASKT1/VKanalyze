# Copy this to .env.local and fill in your values
# Never commit .env.local to version control

# ── Frontend (Vite) — these are intentionally public ──────────────────────────
# Both values are safe to expose: the anon key is limited by Supabase RLS.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Edge Function secrets (set via Supabase dashboard, NOT here) ─────
# Never prefix these with VITE_ — they must never reach the browser.
#
# GEMINI_API_KEY=AIza...          # Primary Gemini key
# GEMINI_API_KEY_2=AIza...        # Optional failover key
# GEMINI_API_KEY_3=AIza...        # Optional failover key
#
# PRODUCTION_ORIGIN=https://yourdomain.com   # Exact CORS origin for production
# PREVIEW_ORIGIN=https://preview.yourdomain.com  # Optional staging origin
